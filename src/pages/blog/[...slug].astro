---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import '../../styles/ironworks.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' });
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{post.data.title} — Mnemra</title>
  <meta name="description" content={post.data.summary}>

  <!-- Open Graph -->
  <meta property="og:title" content={`${post.data.title} — Mnemra`}>
  <meta property="og:description" content={post.data.summary}>
  <meta property="og:type" content="article">
  <meta property="og:url" content={`https://mnemra.dev/blog/${post.id}`}>
  <meta property="og:image" content="https://mnemra.dev/og.png">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={`${post.data.title} — Mnemra`}>
  <meta name="twitter:description" content={post.data.summary}>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600;700;900&family=IBM+Plex+Mono:wght@400;500&family=Source+Sans+3:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="icon" type="image/png" href="/favicon.png">
  <style is:global>
    .post-header {
      margin-bottom: 2rem;
    }
    .post-header h1 {
      font-family: var(--font-heading);
      font-weight: 900;
      font-size: 2.25rem;
      letter-spacing: 0.04em;
      color: var(--raw-text-primary);
      margin-bottom: 0.5rem;
      line-height: 1.15;
    }
    .post-meta {
      font-family: var(--font-mono);
      font-size: 0.8125rem;
      color: var(--raw-text-muted);
      margin-bottom: 0.75rem;
    }
    .post-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
    }
    .tag {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--raw-brass);
      border: 1px solid rgba(176, 141, 87, 0.35);
      padding: 0.15rem 0.5rem;
      border-radius: 2px;
    }
    .post-hero {
      width: 100%;
      height: auto;
      border-radius: 2px;
      margin-bottom: 2rem;
      display: block;
    }
    .post-body {
      font-size: 1.0625rem;
      color: var(--raw-text-secondary);
      line-height: 1.7;
    }
    .post-body h2,
    .post-body h3,
    .post-body h4 {
      font-family: var(--font-heading);
      font-weight: 700;
      color: var(--raw-text-primary);
      margin-top: 2rem;
      margin-bottom: 0.75rem;
      letter-spacing: 0.03em;
    }
    .post-body h2 { font-size: 1.5rem; }
    .post-body h3 { font-size: 1.25rem; }
    .post-body h4 { font-size: 1.0625rem; }
    .post-body p { margin-bottom: 1rem; }
    .post-body ul,
    .post-body ol {
      padding-left: 1.5rem;
      margin-bottom: 1rem;
    }
    .post-body li { margin-bottom: 0.375rem; }
    .post-body a {
      color: var(--raw-brass-light);
      text-decoration: underline;
      text-underline-offset: 2px;
    }
    .post-body a:hover { color: var(--raw-gold); }
    .post-body code {
      font-family: var(--font-mono);
      font-size: 0.875em;
      background: var(--raw-bg-surface);
      padding: 0.1em 0.35em;
      border-radius: 2px;
      color: var(--raw-text-primary);
    }
    .post-body pre {
      background: var(--raw-bg-surface);
      border: 1px solid rgba(176, 141, 87, 0.15);
      border-radius: 2px;
      padding: 1rem;
      overflow-x: auto;
      margin-bottom: 1rem;
    }
    .post-body pre code {
      background: transparent;
      padding: 0;
    }
    .post-body blockquote {
      border-left: 2px solid var(--raw-brass);
      padding-left: 1rem;
      margin: 1rem 0;
      color: var(--raw-text-muted);
    }
    .post-body img {
      max-width: 100%;
      height: auto;
      border-radius: 2px;
      display: block;
      margin: 1.5rem 0;
    }
    .back-link {
      display: inline-block;
      margin-bottom: 2rem;
      font-family: var(--font-heading);
      font-weight: 600;
      font-size: 0.75rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--raw-text-secondary);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: color 150ms ease, border-color 150ms ease;
      padding-bottom: 2px;
    }
    .back-link:hover {
      color: var(--raw-brass-light);
      border-bottom-color: var(--raw-brass-light);
    }
    @media (max-width: 640px) {
      .post-header h1 { font-size: 1.75rem; }
    }
  </style>
</head>
<body>
  <main class="container">
    <a href="/blog" class="back-link">&larr; Blog</a>

    <article>
      <header class="post-header">
        <h1>{post.data.title}</h1>
        <div class="post-meta">{formatDate(post.data.date)}</div>
        {post.data.tags.length > 0 && (
          <div class="post-tags">
            {post.data.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </header>

      {post.data.hero && (
        <Image
          src={post.data.hero}
          alt={post.data.title}
          class="post-hero"
          loading="lazy"
          widths={[640, 960, 1280]}
          sizes="(max-width: 640px) 640px, (max-width: 1024px) 960px, 1280px"
        />
      )}

      <div class="post-body">
        <Content />
      </div>
    </article>
  </main>
</body>
</html>
